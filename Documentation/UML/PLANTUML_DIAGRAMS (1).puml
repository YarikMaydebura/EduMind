@startuml EduMind_ClassDiagram

skinparam backgroundColor #1a1a2e
skinparam class {
    BackgroundColor #16213e
    BorderColor #0f3460
    FontColor #ffffff
    AttributeFontColor #e94560
    StereotypeFontColor #f39c12
}

' ─────────────────────────────────────────────────────────────────────────────
' ENUMS
' ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
    TECH_ADMIN
    SCHOOL_ADMIN
    TEACHER
    STUDENT
    PARENT
}

enum Subject {
    MATHEMATICS
    ENGLISH
    PHYSICS
    CHEMISTRY
    BIOLOGY
    HISTORY
    ...
}

enum Grade {
    E
    D
    C
    B
    A
    S
    S_PLUS
}

enum AchievementRarity {
    COMMON
    UNCOMMON
    RARE
    EPIC
    LEGENDARY
    MYTHIC
}

' ─────────────────────────────────────────────────────────────────────────────
' CORE CLASSES
' ─────────────────────────────────────────────────────────────────────────────

abstract class User {
    - id: UUID
    - email: String
    - passwordHash: String
    - role: UserRole
    - firstName: String
    - lastName: String
    - language: String
    - theme: String
    --
    + login(): Session
    + logout(): void
    + updateProfile(): User
    + changePassword(): void
}

class Teacher {
    - id: UUID
    - userId: UUID
    - subjects: Subject[]
    - isPrivateTutor: Boolean
    --
    + createClass(): Class
    + createLesson(): Lesson
    + assignHomework(): Homework
    + createQuiz(): Quiz
    + gradeSubmission(): void
    + generateLessonPlan(): LessonPlan
}

class Student {
    - id: UUID
    - userId: UUID
    - gradeYear: GradeYear
    - totalXp: Int
    - overallLevel: Int
    - currentGrade: Grade
    - streakDays: Int
    - avatarUrl: String
    --
    + submitHomework(): HomeworkSubmission
    + takeQuiz(): QuizResult
    + earnXP(amount: Int): void
    + levelUp(): void
    + unlockAchievement(): StudentAchievement
    + updateStreak(): void
}

class Parent {
    - id: UUID
    - userId: UUID
    - alertOnLowGrade: Boolean
    --
    + viewChildProgress(): Report
    + contactTeacher(): Message
    + getAlerts(): Notification[]
}

class Class {
    - id: UUID
    - name: String
    - subject: Subject
    - gradeYear: GradeYear
    - lessonsPerWeek: Int
    - isArchived: Boolean
    --
    + generateInvite(): Invite
    + addStudent(student: Student): void
    + removeStudent(student: Student): void
    + archive(): void
    + getStats(): ClassStats
}

class Lesson {
    - id: UUID
    - title: String
    - topic: String
    - scheduledAt: DateTime
    - duration: Int
    - status: LessonStatus
    --
    + start(): void
    + complete(): void
    + trackAttendance(): void
    + generatePlan(): LessonPlan
}

class Homework {
    - id: UUID
    - title: String
    - dueAt: DateTime
    - maxScore: Int
    - baseXpReward: Int
    --
    + assignToClass(): void
    + getSubmissions(): HomeworkSubmission[]
    + checkWithAI(): AIFeedback
}

class Quiz {
    - id: UUID
    - title: String
    - type: QuizType
    - questions: Question[]
    - timeLimit: Int
    - isBossBattle: Boolean
    --
    + start(): QuizAttempt
    + submit(): QuizResult
    + calculateScore(): Int
}

class Achievement {
    - id: UUID
    - name: String
    - description: String
    - icon: String
    - category: String
    - rarity: AchievementRarity
    - conditionType: String
    - conditionValue: Int
    - xpReward: Int
    --
    + checkCondition(student: Student): Boolean
}

' ─────────────────────────────────────────────────────────────────────────────
' SERVICES
' ─────────────────────────────────────────────────────────────────────────────

class XPCalculator <<service>> {
    + calculateHomeworkXP(score, max, isLate): XPEvent
    + calculateQuizXP(score, max, isBoss): XPEvent
    + calculateStreakXP(days): XPEvent
    + calculateLevel(xp): Int
    + calculateGrade(level, hwAvg, quizAvg): Grade
}

class AIService <<service>> {
    + generateLearningPlan(class): LearningPlan
    + generateLessonPlan(lesson): LessonPlan
    + generateQuiz(params): Quiz
    + generateHomework(params): Homework
    + checkHomework(submission): AIFeedback
    + studentTutor(message): Response
}

class AchievementChecker <<service>> {
    + checkAchievements(student, event): Achievement[]
    + evaluateCondition(achievement, student): Boolean
}

' ─────────────────────────────────────────────────────────────────────────────
' RELATIONSHIPS
' ─────────────────────────────────────────────────────────────────────────────

User <|-- Teacher
User <|-- Student
User <|-- Parent

Teacher "1" --> "*" Class : teaches
Teacher "1" --> "*" Lesson : conducts
Teacher "1" --> "*" Homework : assigns
Teacher "1" --> "*" Quiz : creates

Student "*" --> "*" Class : enrolled in
Student "1" --> "*" Achievement : earns

Parent "*" --> "*" Student : monitors

Class "1" --> "*" Lesson : contains
Class "1" --> "*" Homework : has
Class "1" --> "*" Quiz : has

Lesson ..> AIService : uses
Homework ..> AIService : uses
Quiz ..> AIService : uses

Student ..> XPCalculator : uses
Student ..> AchievementChecker : uses

@enduml


