@startuml EduMind_ERD_Complete

!define TABLE(x) entity x << (T,#FFAAAA) >>
!define PRIMARY_KEY(x) <b><color:#b8860b><&key></color> x</b>
!define FOREIGN_KEY(x) <color:#aaaaaa><&link-intact></color> x
!define COLUMN(x) <color:#efefef><&media-record></color> x

skinparam backgroundColor #1a1a2e
skinparam entity {
    BackgroundColor #16213e
    BorderColor #0f3460
    FontColor #e94560
}

' ─────────────────────────────────────────────────────────────────────────────
' TENANT & USER
' ─────────────────────────────────────────────────────────────────────────────

TABLE(Tenant) {
    PRIMARY_KEY(id): UUID
    COLUMN(type): TenantType
    COLUMN(name): String
    COLUMN(slug): String <<unique>>
    COLUMN(plan): SubscriptionPlan
    COLUMN(max_students): Int
    COLUMN(ai_requests_used): Int
    COLUMN(created_at): DateTime
}

TABLE(User) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(tenant_id): UUID
    COLUMN(email): String <<unique>>
    COLUMN(password_hash): String
    COLUMN(role): UserRole
    COLUMN(first_name): String
    COLUMN(last_name): String
    COLUMN(language): Language
    COLUMN(theme): ThemePreference
    COLUMN(last_active_at): DateTime
}

TABLE(Session) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(user_id): UUID
    COLUMN(token): String
    COLUMN(expires_at): DateTime
    COLUMN(ip_address): String
}

' ─────────────────────────────────────────────────────────────────────────────
' ROLE PROFILES
' ─────────────────────────────────────────────────────────────────────────────

TABLE(Teacher) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(user_id): UUID <<unique>>
    COLUMN(subjects): Subject[]
    COLUMN(is_private_tutor): Boolean
    COLUMN(preferences): JSON
}

TABLE(Student) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(user_id): UUID <<unique>>
    COLUMN(grade_year): GradeYear
    COLUMN(total_xp): Int
    COLUMN(overall_level): Int
    COLUMN(current_grade): Grade
    COLUMN(streak_days): Int
    COLUMN(avatar_url): String
    COLUMN(avatar_style): AvatarStyle
}

TABLE(Parent) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(user_id): UUID <<unique>>
    COLUMN(alert_on_low_grade): Boolean
    COLUMN(weekly_digest): Boolean
}

TABLE(ParentStudent) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(parent_id): UUID
    FOREIGN_KEY(student_id): UUID
    COLUMN(verified): Boolean
}

' ─────────────────────────────────────────────────────────────────────────────
' CLASS & ENROLLMENT
' ─────────────────────────────────────────────────────────────────────────────

TABLE(Class) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(tenant_id): UUID
    FOREIGN_KEY(teacher_id): UUID
    COLUMN(name): String
    COLUMN(subject): Subject
    COLUMN(grade_year): GradeYear
    COLUMN(lessons_per_week): Int
    COLUMN(is_archived): Boolean
}

TABLE(ClassEnrollment) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(class_id): UUID
    FOREIGN_KEY(student_id): UUID
    COLUMN(is_active): Boolean
    COLUMN(joined_at): DateTime
}

TABLE(StudentClassProfile) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(student_id): UUID
    FOREIGN_KEY(class_id): UUID
    COLUMN(class_xp): Int
    COLUMN(class_level): Int
    COLUMN(class_grade): Grade
    COLUMN(skills): JSON
}

TABLE(Invite) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(tenant_id): UUID
    FOREIGN_KEY(class_id): UUID
    COLUMN(code): String <<unique>>
    COLUMN(role): UserRole
    COLUMN(max_uses): Int
    COLUMN(used_count): Int
    COLUMN(expires_at): DateTime
}

' ─────────────────────────────────────────────────────────────────────────────
' LEARNING CONTENT
' ─────────────────────────────────────────────────────────────────────────────

TABLE(LearningPlan) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(class_id): UUID <<unique>>
    COLUMN(title): String
    COLUMN(total_weeks): Int
    COLUMN(phases): JSON
    COLUMN(generated_by_ai): Boolean
}

TABLE(Lesson) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(class_id): UUID
    FOREIGN_KEY(teacher_id): UUID
    COLUMN(title): String
    COLUMN(topic): String
    COLUMN(scheduled_at): DateTime
    COLUMN(duration): Int
    COLUMN(status): LessonStatus
}

TABLE(LessonPlan) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(lesson_id): UUID <<unique>>
    COLUMN(structure): JSON
    COLUMN(materials): JSON
    COLUMN(objectives): String[]
    COLUMN(generated_by_ai): Boolean
}

TABLE(LessonAttendance) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(lesson_id): UUID
    FOREIGN_KEY(student_id): UUID
    COLUMN(present): Boolean
    COLUMN(participation_score): Int
}

' ─────────────────────────────────────────────────────────────────────────────
' HOMEWORK & QUIZZES
' ─────────────────────────────────────────────────────────────────────────────

TABLE(Homework) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(class_id): UUID
    FOREIGN_KEY(teacher_id): UUID
    FOREIGN_KEY(lesson_id): UUID
    COLUMN(title): String
    COLUMN(due_at): DateTime
    COLUMN(max_score): Int
    COLUMN(base_xp_reward): Int
    COLUMN(generated_by_ai): Boolean
}

TABLE(HomeworkSubmission) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(homework_id): UUID
    FOREIGN_KEY(student_id): UUID
    COLUMN(content): Text
    COLUMN(status): SubmissionStatus
    COLUMN(score): Int
    COLUMN(teacher_feedback): Text
    COLUMN(ai_feedback): Text
    COLUMN(xp_earned): Int
}

TABLE(Quiz) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(class_id): UUID
    FOREIGN_KEY(teacher_id): UUID
    COLUMN(title): String
    COLUMN(type): QuizType
    COLUMN(questions): JSON
    COLUMN(time_limit): Int
    COLUMN(is_boss_battle): Boolean
    COLUMN(generated_by_ai): Boolean
}

TABLE(QuizResult) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(quiz_id): UUID
    FOREIGN_KEY(student_id): UUID
    COLUMN(attempt_number): Int
    COLUMN(score): Int
    COLUMN(percentage): Float
    COLUMN(answers): JSON
    COLUMN(time_spent): Int
    COLUMN(xp_earned): Int
}

' ─────────────────────────────────────────────────────────────────────────────
' GAMIFICATION
' ─────────────────────────────────────────────────────────────────────────────

TABLE(Achievement) {
    PRIMARY_KEY(id): UUID
    COLUMN(name): String
    COLUMN(description): String
    COLUMN(icon): String
    COLUMN(category): AchievementCategory
    COLUMN(rarity): AchievementRarity
    COLUMN(condition_type): String
    COLUMN(condition_value): Int
    COLUMN(xp_reward): Int
    COLUMN(is_hidden): Boolean
}

TABLE(StudentAchievement) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(student_id): UUID
    FOREIGN_KEY(achievement_id): UUID
    FOREIGN_KEY(class_id): UUID
    COLUMN(progress): Int
    COLUMN(is_unlocked): Boolean
    COLUMN(unlocked_at): DateTime
}

TABLE(ActivityFeed) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(student_id): UUID
    COLUMN(type): ActivityType
    COLUMN(title): String
    COLUMN(description): String
    COLUMN(xp_gained): Int
    COLUMN(is_public): Boolean
    COLUMN(created_at): DateTime
}

TABLE(LeaderboardEntry) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(student_id): UUID
    COLUMN(scope): String
    COLUMN(period): LeaderboardPeriod
    COLUMN(rank): Int
    COLUMN(xp): Int
    COLUMN(calculated_at): DateTime
}

' ─────────────────────────────────────────────────────────────────────────────
' COMMUNICATION
' ─────────────────────────────────────────────────────────────────────────────

TABLE(Notification) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(user_id): UUID
    COLUMN(type): NotificationType
    COLUMN(title): String
    COLUMN(message): String
    COLUMN(read): Boolean
    COLUMN(action_url): String
    COLUMN(created_at): DateTime
}

TABLE(Message) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(sender_id): UUID
    FOREIGN_KEY(receiver_id): UUID
    COLUMN(content): Text
    COLUMN(read): Boolean
    COLUMN(created_at): DateTime
}

' ─────────────────────────────────────────────────────────────────────────────
' AI LOGS
' ─────────────────────────────────────────────────────────────────────────────

TABLE(AiGenerationLog) {
    PRIMARY_KEY(id): UUID
    FOREIGN_KEY(tenant_id): UUID
    FOREIGN_KEY(user_id): UUID
    COLUMN(type): AiTaskType
    COLUMN(model): String
    COLUMN(input_tokens): Int
    COLUMN(output_tokens): Int
    COLUMN(cost_usd): Decimal
    COLUMN(latency_ms): Int
    COLUMN(success): Boolean
    COLUMN(created_at): DateTime
}

' ─────────────────────────────────────────────────────────────────────────────
' RELATIONSHIPS
' ─────────────────────────────────────────────────────────────────────────────

Tenant ||--o{ User
Tenant ||--o{ Class
Tenant ||--o{ Invite
Tenant ||--o{ AiGenerationLog

User ||--o| Teacher
User ||--o| Student
User ||--o| Parent
User ||--o{ Session
User ||--o{ Notification
User ||--o{ Message

Teacher ||--o{ Class
Teacher ||--o{ Lesson
Teacher ||--o{ Homework
Teacher ||--o{ Quiz

Student ||--o{ ClassEnrollment
Student ||--o{ StudentClassProfile
Student ||--o{ HomeworkSubmission
Student ||--o{ QuizResult
Student ||--o{ StudentAchievement
Student ||--o{ ActivityFeed
Student ||--o{ LeaderboardEntry
Student ||--o{ LessonAttendance

Parent ||--o{ ParentStudent
ParentStudent }o--|| Student

Class ||--o{ ClassEnrollment
Class ||--o{ StudentClassProfile
Class ||--o{ Lesson
Class ||--o{ Homework
Class ||--o{ Quiz
Class ||--o| LearningPlan
Class ||--o{ Invite

Lesson ||--o| LessonPlan
Lesson ||--o{ LessonAttendance
Lesson ||--o{ Homework
Lesson ||--o{ Quiz

