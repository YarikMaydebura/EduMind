title ⚔️ Battle State Diagram

[*] --> Unawakened : New student

state Unawakened {
    Unawakened : Level 1-4
    Unawakened : No class
    Unawakened : No battle access
    Unawakened : Building stats through study
}

Unawakened --> Awakening : Level 5 reached

state Awakening {
