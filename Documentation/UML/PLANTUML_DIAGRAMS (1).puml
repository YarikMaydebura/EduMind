' ║ 13. BATTLE SYSTEM - CLASS DIAGRAM                                            ║
' ╚═══════════════════════════════════════════════════════════════════════════════╝

@startuml EduMind_Battle_ClassDiagram

skinparam backgroundColor #1a1a2e
skinparam class {
    BackgroundColor #16213e
    BorderColor #0f3460
    FontColor #ffffff
    AttributeFontColor #e94560
}

title ⚔️ EduMind Battle System - Class Diagram

' ─────────────────────────────────────────────────────────────────────────────
' ENUMS
' ─────────────────────────────────────────────────────────────────────────────

enum Theme {
    FANTASY
    CYBERPUNK
    MILITARY
    SCI_FI
    ANIME
    STEAMPUNK
}

enum ClassRarity {
    COMMON
    UNCOMMON
    RARE
    EPIC
    LEGENDARY
    MYTHIC
}

enum SkillType {
    PHYSICAL
    MAGIC
    HYBRID
    HEAL
    BUFF
    DEBUFF
    STATUS
    ULTIMATE
}

' ─────────────────────────────────────────────────────────────────────────────
' CORE CLASSES
' ─────────────────────────────────────────────────────────────────────────────

class Student {
    - id: UUID
    - subjectStats: Map<Subject, Stats>
    - achievements: Achievement[]
    - level: Int
    --
    + getBattleCharacter(): BattleCharacter
}

class BattleCharacter {
    - id: UUID
    - studentId: UUID
    - classId: UUID
    - theme: Theme
    ==ATTRIBUTES==
    - hp: Int
    - mp: Int
    - sta: Int
    - atk: Int
    - def: Int
    - spd: Int
    - lck: Int
    ==BATTLE STATS==
    - battlesWon: Int
    - battlesLost: Int
    - knowledgePoints: Int
    --
    + calculateStats(): void
    + equipSkill(skill): void
    + startBattle(enemy): Battle
    + useSkill(skill): DamageResult
    + basicAttack(): DamageResult
}

class CharacterClass {
    - id: UUID
    - name: String
    - theme: Theme
    - rarity: ClassRarity
    - passives: PassiveBonus[]
    - abilities: Ability[]
    - requirements: Requirements
    --
    + checkUnlockConditions(student): Boolean
    + getPassiveBonus(): Stats
    + canEvolveTo(): CharacterClass[]
}

class Skill {
    - id: UUID
    - name: String
    - type: SkillType
    - rarity: SkillRarity
    - mpCost: Int
    - staCost: Int
    - power: Int
    - cooldown: Int
    - effects: Effect[]
    - unlockConditions: Conditions
    --
    + checkUnlock(student, character): Boolean
    + execute(attacker, defender): SkillResult
    + calculateDamage(attacker, defender): Int
}

class Battle {
    - id: UUID
    - type: BattleType
    - player1: BattleCharacter
    - player2: BattleCharacter
    - battleLog: TurnLog[]
    - currentTurn: Int
    --
    + start(): void
    + executeTurn(action): TurnResult
    + checkWinCondition(): Winner?
    + calculateRewards(): Rewards
}

class Item {
    - id: UUID
    - name: String
    - type: ItemType
    - rarity: ItemRarity
    - price: Int
    - effects: Effect[]
    --
    + use(character): UseResult
    + canEquip(character): Boolean
}

' ─────────────────────────────────────────────────────────────────────────────
' SERVICES
' ─────────────────────────────────────────────────────────────────────────────

class BattleService <<service>> {
    + createBattle(p1, p2): Battle
    + processTurn(battle, action): TurnResult
    + calculateDamage(attacker, defender, skill): Int
    + applyStatusEffects(character): void
    + endBattle(battle): Rewards
}

class StatsCalculator <<service>> {
    + calculateFromSubjects(student): BaseStats
    + applyClassBonus(stats, class): Stats
    + applyEquipment(stats, items): Stats
    + getFinalStats(character): Stats
}

class ClassUnlockService <<service>> {
    + getAvailableClasses(student): CharacterClass[]
    + proposeClasses(student, count): CharacterClass[]
    + evolveClass(character, newClass): void
    + checkEvolutionConditions(character): CharacterClass[]
}

class SkillUnlockService <<service>> {
    + getAvailableSkills(student, character): Skill[]
    + checkUnlockConditions(skill, student): Boolean
    + unlockSkill(character, skill): void
}

' ─────────────────────────────────────────────────────────────────────────────
' RELATIONSHIPS
' ─────────────────────────────────────────────────────────────────────────────

Student "1" --> "0..1" BattleCharacter : has
BattleCharacter "1" --> "1" CharacterClass : uses
BattleCharacter "1" --> "*" Skill : equips
BattleCharacter "1" --> "*" Item : owns
BattleCharacter "*" --> "*" Battle : participates

CharacterClass --> Theme
CharacterClass --> ClassRarity
CharacterClass "1" --> "*" CharacterClass : evolves to

Skill --> SkillType
Skill --> CharacterClass : exclusive to

Battle --> BattleService : uses
BattleCharacter --> StatsCalculator : uses

@enduml


' ╔═══════════════════════════════════════════════════════════════════════════════╗
' ║ 14. BATTLE SEQUENCE - PVP BATTLE FLOW                                        ║
' ╚═══════════════════════════════════════════════════════════════════════════════╝

@startuml EduMind_Battle_Sequence

skinparam backgroundColor #1a1a2e
skinparam sequence {
    ParticipantBackgroundColor #16213e
    ParticipantBorderColor #0f3460
    ParticipantFontColor #ffffff
    ActorBackgroundColor #e94560
    ArrowColor #3498db
}

title ⚔️ PvP Battle Flow

actor "Player 1" as P1
actor "Player 2" as P2
participant "Battle UI" as UI
participant "Battle Service" as BS
participant "Stats Calculator" as SC
database "Database" as DB

== Battle Initialization ==

P1 -> UI: Challenge Player 2
UI -> BS: createBattle(p1Id, p2Id)
BS -> DB: Check daily limits
DB --> BS: Limits OK

BS -> SC: calculateFinalStats(player1)
SC -> DB: Get subject stats
DB --> SC: Subject averages
SC -> SC: Apply subject conversions
SC -> SC: Apply class bonus
SC -> SC: Apply equipment
SC --> BS: Player 1 stats

BS -> SC: calculateFinalStats(player2)
SC --> BS: Player 2 stats

BS -> DB: Create battle record
BS --> UI: Battle ready

UI --> P1: Battle starts!
UI --> P2: Battle starts!

== Turn Loop ==

loop Until HP <= 0 or Turn 30

    BS -> BS: Calculate turn order (SPD)
    
    alt Player 1 faster
        UI --> P1: Your turn!
        
        P1 -> UI: Choose action
        
        alt Basic Attack
            UI -> BS: basicAttack()
            BS -> BS: damage = ATK × 1.0
            BS -> BS: Apply defense reduction
            BS -> BS: Check critical hit
            BS -> DB: Update HP
            BS --> UI: Damage result
        else Use Skill
            UI -> BS: useSkill(skillId)
            BS -> BS: Check MP/STA cost
            BS -> BS: damage = power × ATK / 100
            BS -> BS: Apply effects
            BS -> BS: Start cooldown
            BS -> DB: Update HP/MP/STA
            BS --> UI: Skill result
        else Defend
            UI -> BS: defend()
            BS -> BS: +50% DEF this turn
            BS -> BS: Recover +10 MP, +10 STA
            BS --> UI: Defend active
        else Use Item
            UI -> BS: useItem(itemId)
            BS -> BS: Apply item effect
            BS -> DB: Remove item from inventory
            BS --> UI: Item used
        end
        
        UI --> P1: Action complete
        UI --> P2: Enemy action result
        
    else Player 2 faster
        UI --> P2: Your turn!
        note right: Same flow for Player 2
    end
    
    == End of Turn ==
    
    BS -> BS: Apply status effects (burn, poison)
    BS -> BS: Reduce buff/debuff durations
    BS -> BS: Regenerate +5 MP, +5 STA
    BS -> BS: Check skill cooldowns
    
    BS -> BS: Check win condition
    
end

== Battle End ==

alt Player 1 wins
    BS -> BS: Calculate rewards
    note right
        Winner: 50-100 XP, 50-100 KP
        10% item drop
        5% skill book drop
    end note
    
    BS -> DB: Award XP to winner
    BS -> DB: Award KP to both
    BS -> DB: Update battle stats
    BS -> DB: Check skill drops
    
    BS --> UI: Battle complete
    UI --> P1: Victory! +75 XP, +80 KP
    UI --> P2: Defeat. +20 XP, +20 KP
    
else Player 2 wins
    note right: Same as above, reversed
    
else Draw (30 turns)
    BS -> DB: Award 35 XP, 35 KP to both
    UI --> P1: Draw!
    UI --> P2: Draw!
end

@enduml


