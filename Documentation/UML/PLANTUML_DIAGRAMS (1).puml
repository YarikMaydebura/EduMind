state InBattle {
    state "Turn Start" as TS
    state "Action Selection" as AS
    state "Action Execution" as AE
    state "Status Effects" as SE
    state "Turn End" as TE
    state "Win Check" as WC
    
    TS --> AS : Determine turn order
    AS --> AE : Player chooses action
    AE --> SE : Execute action
    SE --> TE : Apply effects
    TE --> WC : Regen MP/STA
