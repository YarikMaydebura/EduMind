# ═══════════════════════════════════════════════════════════════
# EDUMIND AI - Environment Variables
# Copy to .env.local and fill in values
# ═══════════════════════════════════════════════════════════════

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edumind
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/edumind

# Authentication (NextAuth.js)
NEXTAUTH_SECRET=your-development-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=

# Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=edumind

# Email (Resend)
RESEND_API_KEY=

# Payments (Paddle)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
